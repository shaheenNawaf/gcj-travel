---
import ConversionBanner from '../components/ConversionBanner.astro';
import PublicLayout from '../layouts/PublicLayout.astro';
import PackageGrid from '../components/PackageGrid.jsx';
import { supabase } from '../lib/supabase_client';

const intlRegions = ['All', 'Japan', 'South Korea', 'China', 'Southeast Asia', 'Europe'];

const { data: packages } = await supabase
  .from('packages')
  .select('*')
  .eq('status', 'active')
  .eq('is_international', true)
  .order('price', { ascending: true });
---

<PublicLayout title="International Tours">
  <main class="pt-36 pb-24">
    <div class="container mx-auto px-6">
      <div class="max-w-2xl mb-12 space-y-3 pb-8 border-b border-border">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-teal">Global Horizons</p>
        <h1 class="text-5xl font-serif text-ink font-light leading-tight">Global Journeys</h1>
        <p class="text-ink-muted text-base leading-relaxed">Experience the world with GCJ's signature comfort. Curated international itineraries designed for seamless global explorations.</p>
      </div>
      <PackageGrid 
  client:load 
  initialPackages={(packages || []) as any[]} 
  regions={intlRegions} 
/>
    </div>
  </main>
  <ConversionBanner />
</PublicLayout>