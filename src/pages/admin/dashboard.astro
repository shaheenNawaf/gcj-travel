---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { supabase } from '@lib/supabase_client';

// Fetch dynamic catalog and inquiry datasets [1]
const { data: packages } = await supabase.from('packages').select('*');
const { data: inquiries } = await supabase.from('inquiries').select('*').order('created_at', { ascending: false });

const totalInquiries = inquiries?.length || 0;
const totalPackages = packages?.length || 0;

// Calculate pending requests [1]
const pendingLeads = inquiries?.filter(i => i.status === 'new' || !i.status).length || 0;

// Advanced Pipeline Metric: Aggregate starting prices of requested packages
// to show "projected booking value" on screen.
const potentialRevenue = inquiries?.reduce((acc, curr) => {
  const matchedPkg = packages?.find(p => p.title === curr.package_title || p.id === curr.package_id);
  return acc + (matchedPkg?.price || 0);
}, 0) || 0;
---

<AdminLayout title="Command Center">
  <div class="space-y-12">
    <div>
      <h1 class="font-serif text-5xl mb-4 text-ink">Dashboard</h1>
      <p class="text-ink-muted max-w-xl text-sm">Real-time business performance analytics, active pipeline values, and recent traveler inquiries.</p>
    </div>

    <!-- Metrics Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="bg-white border border-border p-6 rounded-2xl flex flex-col justify-between space-y-4 shadow-sm">
        <span class="text-[10px] font-bold text-ink-muted/50 uppercase tracking-widest">Active Catalog</span>
        <div>
          <p class="text-4xl font-mono font-bold text-ink leading-tight">{totalPackages}</p>
          <p class="text-xs text-ink-muted/60 mt-1">Published Tour Packages</p>
        </div>
      </div>

      <div class="bg-white border border-border p-6 rounded-2xl flex flex-col justify-between space-y-4 shadow-sm">
        <span class="text-[10px] font-bold text-teal uppercase tracking-widest">Pending Leads</span>
        <div>
          <p class="text-4xl font-mono font-bold text-teal leading-tight">{pendingLeads}</p>
          <p class="text-xs text-ink-muted/60 mt-1">Awaiting Response</p>
        </div>
      </div>

      <div class="bg-white border border-border p-6 rounded-2xl flex flex-col justify-between space-y-4 shadow-sm">
        <span class="text-[10px] font-bold text-ink uppercase tracking-widest">Total Funnel</span>
        <div>
          <p class="text-4xl font-mono font-bold text-ink leading-tight">{totalInquiries}</p>
          <p class="text-xs text-ink-muted/60 mt-1">Lifetime Inquiries Received</p>
        </div>
      </div>

      <div class="bg-white border border-border p-6 rounded-2xl flex flex-col justify-between space-y-4 shadow-sm">
        <span class="text-[10px] font-bold text-coral uppercase tracking-widest">Est. Pipeline Value</span>
        <div>
          <p class="text-4xl font-mono font-bold text-coral leading-tight">₱{potentialRevenue.toLocaleString()}</p>
          <p class="text-xs text-ink-muted/60 mt-1">Based on Requested Tours</p>
        </div>
      </div>
    </div>

    <!-- Recent Activity Section -->
    <div class="bg-white border border-border rounded-2xl shadow-sm overflow-hidden">
      <div class="p-6 border-b border-border flex justify-between items-center bg-sand/20">
        <h3 class="font-serif text-2xl text-ink font-semibold">Recent Inbound Activity</h3>
        <a href="/admin/inquiries" class="text-xs font-bold text-teal hover:text-teal-dark border-b-2 border-teal hover:border-teal-dark pb-0.5 transition-colors">Manage All Leads →</a>
      </div>

      <div class="divide-y divide-border">
        {inquiries?.slice(0, 4).map(item => (
          <div class="p-6 flex items-center justify-between hover:bg-surface/30 transition-colors">
            <div class="space-y-1">
              <p class="text-sm font-bold text-ink">{item.name}</p>
              <p class="text-xs text-ink-muted">{item.email}</p>
            </div>
            
            <span class="text-xs text-teal font-semibold bg-teal-pale border border-teal/15 px-3 py-1 rounded-full">
              {item.package_title || "Custom Quote"}
            </span>

            <span class="text-xs font-mono text-ink-muted">
              {new Date(item.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </span>
          </div>
        ))}

        {totalInquiries === 0 && (
          <div class="p-12 text-center text-ink-muted text-sm">
            No inquiries received yet. Once customers start submitting requests, they will populate here!
          </div>
        )}
      </div>
    </div>

  </div>
</AdminLayout>