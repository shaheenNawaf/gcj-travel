---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { createClient } from '@supabase/supabase-js';

let feedbackMessage = '';
let isSuccess = false;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get("email") as string;
    const password = formData.get("password") as string;
    const role = formData.get("role") as string; // Read selected role

    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const serviceRoleKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;

    if (!serviceRoleKey) {
      throw new Error("Missing SUPABASE_SERVICE_ROLE_KEY environment variable.");
    }

    const supabaseAdmin = createClient(supabaseUrl, serviceRoleKey, {
      auth: {
        autoRefreshToken: false,
        persistSession: false
      }
    });

    // Create staff user and store their role directly inside user_metadata
    const { data, error } = await supabaseAdmin.auth.admin.createUser({
      email,
      password,
      email_confirm: true,
      user_metadata: { role } // Assign dynamic metadata role [1]
    });

    if (error) {
      feedbackMessage = error.message;
    } else {
      isSuccess = true;
      feedbackMessage = `Success! Account created for ${email} as a ${role === 'superadmin' ? 'Super Admin' : 'Travel Agent'}.`;
    }
  } catch (e: any) {
    feedbackMessage = e.message;
  }
}
---

<AdminLayout title="Staff & Access">
  <div class="space-y-12">
    <div>
      <h1 class="font-serif text-5xl mb-4 text-ink">Staff Access Panel</h1>
      <p class="text-ink-muted max-w-xl text-sm">Provision, manage, and create administrative accounts securely for your agency team members.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
      
      <!-- Create Form -->
      <div class="lg:col-span-2 bg-white border border-border p-8 rounded-3xl shadow-sm space-y-6">
        <h3 class="font-serif text-2xl text-ink font-semibold">Provision New Admin</h3>
        <p class="text-xs text-ink-muted">Enter login credentials below to create a direct staff dashboard account. Email confirmations are bypassed automatically.</p>

        {feedbackMessage && (
          <div class={`p-4 rounded-xl border text-sm ${
            isSuccess ? 'bg-teal-pale border-teal text-teal' : 'bg-red-50 border-red-200 text-red-600'
          }`}>
            {feedbackMessage}
          </div>
        )}

        <form method="POST" class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label class="block text-[10px] font-bold uppercase tracking-widest text-ink-muted">Email Address</label>
              <input required name="email" type="email" placeholder="staff@gcjtravel.com" class="w-full p-4 bg-surface border border-border rounded-xl outline-none text-sm text-ink focus:border-teal transition-colors" />
            </div>
            <div class="space-y-2">
              <label class="block text-[10px] font-bold uppercase tracking-widest text-ink-muted">Temporary Security Key</label>
              <input required name="password" type="password" placeholder="••••••••" minlength="6" class="w-full p-4 bg-surface border border-border rounded-xl outline-none text-sm text-ink focus:border-teal transition-colors" />
            </div>
          </div>

          <!-- Dynamic Role Selector -->
          <div class="space-y-2">
            <label class="block text-[10px] font-bold uppercase tracking-widest text-ink-muted">Assign System Role</label>
            <select required name="role" class="w-full sm:w-1/2 p-4 bg-surface border border-border rounded-xl outline-none text-sm text-ink cursor-pointer focus:border-teal">
              <option value="agent">Travel Agent (Manage Leads, Edit Tours)</option>
              <option value="superadmin">Super Admin (Full Administrative Access)</option>
            </select>
          </div>

          <button type="submit" class="bg-ink hover:bg-teal text-white py-4 px-8 rounded-xl font-bold text-xs uppercase tracking-widest transition-colors duration-200 cursor-pointer">
            Create Access Account
          </button>
        </form>
      </div>

      <div class="lg:col-span-1 bg-sand/35 border border-border p-8 rounded-3xl space-y-4">
        <h4 class="font-sans text-sm font-bold text-ink">Bypassing Supabase Portals</h4>
        <p class="text-xs text-ink-muted leading-relaxed">
          Instead of giving your clients full access to database settings and RLS policies on Supabase, they can securely generate team logins directly here.
        </p>
        <p class="text-xs text-ink-muted leading-relaxed font-semibold text-teal">
          ✓ Secure Server-Side Execution<br/>
          ✓ Hidden Database Credentials<br/>
          ✓ Instant Account confirmation
        </p>
      </div>

    </div>
  </div>
</AdminLayout>