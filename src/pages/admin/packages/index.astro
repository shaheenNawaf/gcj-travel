---
import AdminLayout from '../../../layouts/admin_layout.astro';
import { supabase } from '../../../lib/supabase_client';

const { data: packages } = await supabase
  .from('packages')
  .select('*')
  .order('created_at', { ascending: false });
---

<AdminLayout title="Tour Catalog">
  <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px;">
    <div>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 48px; margin: 0 0 16px;">Magazine Catalog</h1>
      <p style="color: #4b5563; margin: 0;">Manage the featured journeys and destinations in your digital edition.</p>
    </div>
    <a href="/admin/packages/new" class="add-btn">+ Add New Journey</a>
  </div>

  <div class="package-list">
    {packages?.map((pkg) => (
      <div class="package-row">
        <img src={pkg.image_url} alt="" class="row-img" />
        <div class="row-content">
          <div class="row-meta">
            <span class="region-tag">{pkg.region}</span>
            <span class="days-tag">{pkg.days} DAYS</span>
          </div>
          <h3 class="row-title">{pkg.title}</h3>
        </div>
        <div class="row-price">₱{pkg.price.toLocaleString()}</div>
        <div class="row-actions">
          <a href={`/admin/packages/edit/${pkg.id}`} class="action-btn text-decoration: none">Edit</a>
          <button class="action-btn delete" data-id={pkg.id} data-title={pkg.title}> Delete </button>
        </div>
      </div>
    ))}
  </div>

  <style>
    .add-btn {
      background: #1a6b6b;
      color: white;
      padding: 12px 24px;
      border-radius: 12px;
      text-decoration: none;
      font-weight: bold;
      font-size: 14px;
      transition: all 0.2s;
    }
    .add-btn:hover { background: #0d1117; transform: translateY(-2px); }

    .package-list { display: flex; flex-direction: column; gap: 16px; }
    
    .package-row {
      background: white;
      border: 1px solid #e2ddd7;
      border-radius: 20px;
      padding: 16px;
      display: flex;
      align-items: center;
      gap: 24px;
      transition: border-color 0.2s;
    }
    .package-row:hover { border-color: #1a6b6b; }

    .row-img { width: 80px; height: 80px; border-radius: 12px; object-fit: cover; }
    
    .row-content { flex: 1; }
    .row-meta { display: flex; gap: 8px; margin-bottom: 4px; }
    .region-tag { font-size: 10px; font-weight: bold; color: #1a6b6b; background: #e6f4f4; padding: 2px 8px; border-radius: 4px; text-transform: uppercase; }
    .days-tag { font-size: 10px; font-weight: bold; color: #4b5563; padding: 2px 0; }
    .row-title { margin: 0; font-family: 'Cormorant Garamond', serif; font-size: 20px; }

    .row-price { font-family: 'DM Mono', monospace; font-weight: bold; color: #1a6b6b; }

    .row-actions { display: flex; gap: 8px; }
    .action-btn { 
      background: #fafaf8; 
      border: 1px solid #e2ddd7; 
      padding: 8px 16px; 
      border-radius: 8px; 
      font-size: 12px; 
      font-weight: bold; 
      cursor: pointer; 
    }
    .action-btn.delete:hover { color: #dc2626; border-color: #dc2626; }
  </style>
</AdminLayout>

<script>
  import { supabase } from '../../../lib/supabase_client';

  // Find all delete buttons
  const deleteButtons = document.querySelectorAll('.action-btn.delete');

  deleteButtons.forEach(button => {
    button.addEventListener('click', async (e) => {
      const id = (e.currentTarget as HTMLElement).getAttribute('data-id');
      const title = (e.currentTarget as HTMLElement).getAttribute('data-title');

      if (confirm(`Are you sure you want to remove "${title}" from the catalog?`)) {
        const { error } = await supabase
          .from('packages')
          .delete()
          .eq('id', id);

        if (error) {
          alert("Error deleting: " + error.message);
        } else {
          // Refresh the page to show it's gone
          window.location.reload();
        }
      }
    });
  });
</script>