---
import AdminLayout from '@layouts/AdminLayout.astro';
import { supabase } from '@lib/supabase_client';

const { data: packages } = await supabase
  .from('packages')
  .select('*')
  .order('created_at', { ascending: false });
---

<AdminLayout title="Tour Catalog">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 mb-12">
    <div>
      <h1 class="font-serif text-5xl mb-4 text-ink">Magazine Catalog</h1>
      <p class="text-ink-muted max-w-lg leading-relaxed text-sm">Manage the featured journeys and destinations in your digital edition.</p>
    </div>
    <a href="/admin/packages/new" class="bg-teal hover:bg-ink text-white py-3 px-6 rounded-xl font-bold text-sm transition-all shadow-md hover:-translate-y-0.5">
      + Add New Journey
    </a>
  </div>

  <div class="flex flex-col gap-4">
    {packages?.map((pkg) => (
      <div class="bg-white border border-border rounded-2xl p-4 flex flex-col sm:flex-row items-center gap-6 hover:border-teal transition-colors duration-200">
        <img src={pkg.image_url} alt="" class="w-20 h-20 rounded-xl object-cover flex-shrink-0" />
        
        <div class="flex-1 space-y-1.5 text-center sm:text-left">
          <div class="flex flex-wrap justify-center sm:justify-start gap-2 items-center">
            <span class="text-[9px] font-bold text-teal bg-teal-pale px-2.5 py-0.5 rounded uppercase tracking-wider">{pkg.region}</span>
            <span class="text-[10px] font-mono font-bold text-ink-muted/70">{pkg.days} DAYS</span>
          </div>
          <h3 class="font-serif text-2xl text-ink leading-tight">{pkg.title}</h3>
        </div>
        
        <div class="font-mono font-bold text-teal text-lg">
          ₱{pkg.price.toLocaleString()}
        </div>
        
        <div class="flex gap-2">
          <a href={`/admin/packages/edit/${pkg.id}`} class="bg-surface hover:bg-teal hover:text-white border border-border hover:border-teal py-2.5 px-4 rounded-xl text-xs font-bold text-ink transition-all">
            Edit
          </a>
          <button class="bg-surface hover:bg-red-50 hover:text-red-600 border border-border hover:border-red-200 py-2.5 px-4 rounded-xl text-xs font-bold text-ink-muted hover:border-red-200 cursor-pointer delete transition-all" data-id={pkg.id} data-title={pkg.title}>
            Delete
          </button>
        </div>
      </div>
    ))}
  </div>
</AdminLayout>

<script>
  import { supabase } from '../../../lib/supabase_client';

  const deleteButtons = document.querySelectorAll('.delete');

  deleteButtons.forEach(button => {
    button.addEventListener('click', async (e) => {
      const el = e.currentTarget as HTMLElement;
      const id = el.getAttribute('data-id');
      const title = el.getAttribute('data-title');

      if (confirm(`Are you sure you want to remove "${title}" from the catalog?`)) {
        const { error } = await supabase
          .from('packages')
          .delete()
          .eq('id', id);

        if (error) {
          alert('Error deleting: ' + error.message);
        } else {
          window.location.reload();
        }
      }
    });
  });
</script>