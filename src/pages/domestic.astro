---
import ConversionBanner from '../components/conversion_banner.astro';
import PublicLayout from '../layouts/public_layout.astro';
import PackageGrid from '../components/package_grid.jsx';
import { supabase } from '../lib/supabase_client';

const domesticRegions = ['All', 'Luzon', 'Visayas', 'Mindanao', 'Palawan'];

const { data: packages } = await supabase
  .from('packages')
  .select('*')
  .eq('status', 'active')
  .eq('is_international', false)
  .order('price', { ascending: true });
---

<PublicLayout title="Domestic Tour Packages">
  <main class="pt-32 pb-24">
    <div class="container mx-auto px-6">
      <div class="max-w-2xl mb-12">
        <h1 class="text-5xl font-serif text-ink mb-4">Domestic Getaways</h1>
        <p class="text-ink-muted text-lg">Explore the 7,641 islands of the Philippines.</p>
      </div>
      <PackageGrid client:load initialPackages={packages || []} regions={domesticRegions} />
    </div>
  </main>
  <ConversionBanner />
</PublicLayout>