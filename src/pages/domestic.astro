---
import ConversionBanner from '../components/ConversionBanner.astro';
import PublicLayout from '../layouts/PublicLayout.astro';
import PackageGrid from '../components/PackageGrid.jsx';
import { supabase } from '../lib/supabase_client';

const domesticRegions = ['All', 'Luzon', 'Visayas', 'Mindanao', 'Palawan'];

const { data: packages } = await supabase
  .from('packages')
  .select('*')
  .eq('status', 'active')
  .eq('is_international', false)
  .order('price', { ascending: true });
---

<PublicLayout title="Domestic Tour Packages">
  <main class="pt-36 pb-24">
    <div class="container mx-auto px-6">
      <div class="max-w-2xl mb-12 space-y-3 pb-8 border-b border-border">
        <p class="text-[10px] font-bold uppercase tracking-[0.25em] text-teal">Unexplored Islands</p>
        <h1 class="text-5xl font-serif text-ink font-light leading-tight">Domestic Getaways</h1>
        <p class="text-ink-muted text-base leading-relaxed">Discover pristine white-sand beaches, emerald lagoons, and rich cultural traditions across the Philippine archipelago.</p>
      </div>
      <PackageGrid 
  client:load 
  initialPackages={(packages || []) as any[]} 
  regions={domesticRegions} 
/>
    </div>
  </main>
  <ConversionBanner />
</PublicLayout>