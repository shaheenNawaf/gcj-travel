---
import PublicLayout from '../layouts/public_layout.astro';
import { siteConfig } from '../config/site';
---

<PublicLayout title="Contact Us">
  <main class="pt-40 pb-24">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
        <div>
          <h1 class="text-6xl font-serif mb-8 text-ink">Get in <span class="italic">Touch</span></h1>
          <p class="text-ink-muted text-xl mb-12 leading-relaxed">Our travel specialists are ready to help you plan your next heartbeat moment.</p>
          <div class="space-y-8">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-teal mb-2">Direct Line</p>
              <p class="text-2xl font-serif">{siteConfig.contact.phone}</p>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-teal mb-2">Email Inquiry</p>
              <p class="text-2xl font-serif">{siteConfig.contact.email}</p>
            </div>
          </div>
        </div>
        <div class="bg-sand rounded-3xl p-12 flex flex-col justify-center border border-border">
          <h2 class="text-3xl font-serif mb-6">Visit our Socials</h2>
          <div class="flex flex-col gap-4">
            <a href={siteConfig.contact.facebook} class="bg-white border border-border p-4 rounded-xl font-bold text-center hover:border-teal transition-colors">FACEBOOK</a>
            <a href={siteConfig.contact.instagram} class="bg-white border border-border p-4 rounded-xl font-bold text-center hover:border-teal transition-colors">INSTAGRAM</a>
          </div>
        </div>
      </div>
    </div>
  </main>
</PublicLayout>