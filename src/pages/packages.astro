---
import PublicLayout from '../layouts/public_layout.astro';
import ConversionBanner from '../components/conversion_banner.astro';
import PackageGrid from '../components/package_grid.jsx';
import { supabase } from '../lib/supabase_client';

const { data: packages } = await supabase
  .from('packages')
  .select('*')
  .eq('status', 'active')
  .order('price', { ascending: true });

const uniqueRegions = ['All', ...new Set(packages?.map(p => p.region).filter(Boolean))];
---

<PublicLayout title="All Packages">
  <main class="pt-32 pb-24">
    <div class="container mx-auto px-6">
      <div class="max-w-2xl mb-12">
        <h1 class="text-5xl font-serif text-ink mb-4">All Destinations</h1>
        <p class="text-ink-muted text-lg">Domestic getaways and global journeys, all in one place.</p>
      </div>
      <PackageGrid client:load initialPackages={packages || []} regions={uniqueRegions} />
    </div>
  </main>
  <ConversionBanner />
</PublicLayout>