---
export const prerender = false;

import PublicLayout from '@layouts/PublicLayout.astro';
import { supabase } from '@lib/supabase_client';
import { marked } from 'marked';
import ItineraryTimeline from '@components/ItineraryTimeline.astro';

const { id } = Astro.params;
const { data: pkg } = await supabase
  .from('packages')
  .select('*')
  .eq('id', id)
  .single();

if (!pkg) return Astro.redirect('/404');

const descriptionHtml = pkg.description_md ? marked(pkg.description_md) : null;
const allImages: string[] = pkg.images?.length ? pkg.images : pkg.image_url ? [pkg.image_url] : [];
---

<PublicLayout title={pkg.title}>

  <!-- Hero Details Header Banner -->
  <div class="relative h-[70vh] overflow-hidden">
    <img src={allImages[0]} alt={pkg.title} class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-12 container mx-auto">
      <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-coral mb-3">
        {pkg.is_international ? 'International' : 'Domestic'} · {pkg.region}
      </p>
      <h1 class="text-5xl md:text-7xl font-serif text-white mb-6 leading-tight max-w-3xl">{pkg.title}</h1>
      <div class="flex flex-wrap gap-6 text-white/70 text-sm">
        <span>⏱ {pkg.days} Days</span>
        <span>📍 {pkg.region}</span>
        <span class="text-coral font-bold text-lg">₱{pkg.price?.toLocaleString()}</span>
      </div>
    </div>
  </div>

  <!-- Multi-Photo Gallery Stream -->
  {allImages.length > 1 && (
    <div class="container mx-auto px-6 py-10">
      <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-teal mb-6">Photo Gallery</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {allImages.slice(1).map((url: string, i: number) => (
          <div class="aspect-[4/3] overflow-hidden rounded-2xl cursor-pointer gallery-item"
            data-src={url} data-index={i + 1}>
            <img
              src={url}
              alt={`${pkg.title} photo ${i + 2}`}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            />
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Dynamic Lightbox Modal Target -->
  <div id="lightbox" class="hidden fixed inset-0 z-[300] bg-black/90 flex items-center justify-center p-6">
    <button id="lightbox-close" class="absolute top-6 right-6 text-white/70 hover:text-white text-3xl font-light cursor-pointer">✕</button>
    <button id="lightbox-prev" class="absolute left-6 text-white/70 hover:text-white text-4xl font-light cursor-pointer">‹</button>
    <button id="lightbox-next" class="absolute right-16 text-white/70 hover:text-white text-4xl font-light cursor-pointer">›</button>
    <img id="lightbox-img" src="" alt="Lightbox Zoom" class="max-h-[85vh] max-w-full rounded-2xl object-contain" />
  </div>

  <main class="container mx-auto px-6 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Left Column: Rich Text & Inclusions -->
      <div class="lg:col-span-2 space-y-12">
        {pkg.itinerary_days && pkg.itinerary_days.length > 0 ? (
          <div>
            <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-teal mb-6">Daily Timeline</p>
            <ItineraryTimeline days={pkg.itinerary_days} />
          </div>
        ) : (
          descriptionHtml && (
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-teal mb-6">About This Package</p>
              <div class="prose prose-lg max-w-none text-ink-muted leading-relaxed" set:html={descriptionHtml} />
            </div>
          )
        )}

        {pkg.inclusions?.length > 0 && (
          <div>
            <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-teal mb-6">What's Included</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {pkg.inclusions.map((item: string) => (
                <div class="flex items-center gap-3 bg-sand rounded-xl p-4 border border-border">
                  <span class="w-6 h-6 rounded-full bg-teal/10 text-teal flex items-center justify-center text-xs flex-shrink-0">✓</span>
                  <span class="text-sm text-ink">{item}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Right Column: Interactive Booking Calculator Sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-28 bg-white rounded-3xl border border-border p-8 shadow-xl space-y-6">
          
          {/* Real-time Dynamic Pricing Calculator Output Header */}
          <div class="space-y-1">
            <p class="text-[10px] font-bold uppercase tracking-widest text-ink-muted">Estimated Price</p>
            <p class="text-5xl font-serif text-ink" id="calculated-pax-price">₱{pkg.price?.toLocaleString()}</p>
            <p class="text-ink-muted text-xs font-mono" id="calculated-total-summary">₱{pkg.price?.toLocaleString()} per person · {pkg.days} days</p>
          </div>

          <div class="border-t border-border pt-6 space-y-4">
            {/* Travel Date Input */}
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-ink-muted mb-2">1. Target Travel Date</label>
              <input id="sidebar-travel-date" type="date" class="w-full border border-border rounded-xl p-3 text-sm outline-none focus:border-teal text-ink" />
            </div>

            {/* Steppers */}
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-ink-muted mb-2">2. Adjust Travelers</label>
              <div class="flex gap-2">
                <div class="flex items-center justify-between border border-border rounded-xl px-3 py-2 flex-1 bg-surface">
                  <button id="btn-dec-adults" class="text-ink-muted hover:text-ink px-1.5 font-bold cursor-pointer select-none">-</button>
                  <span class="text-xs font-mono font-bold text-ink" id="lbl-adults">2 Ad</span>
                  <button id="btn-inc-adults" class="text-ink-muted hover:text-ink px-1.5 font-bold cursor-pointer select-none">+</button>
                </div>
                <div class="flex items-center justify-between border border-border rounded-xl px-3 py-2 flex-1 bg-surface">
                  <button id="btn-dec-children" class="text-ink-muted hover:text-ink px-1.5 font-bold cursor-pointer select-none">-</button>
                  <span class="text-xs font-mono font-bold text-ink" id="lbl-children">0 Ch</span>
                  <button id="btn-inc-children" class="text-ink-muted hover:text-ink px-1.5 font-bold cursor-pointer select-none">+</button>
                </div>
              </div>
            </div>
          </div>

          {/* Calculator CTA Buttons */}
          <div class="space-y-3">
            <button id="detail-inquire-btn"
              class="w-full bg-coral hover:bg-coral-dark text-white font-bold py-4 rounded-xl transition-all shadow-lg hover:-translate-y-0.5 cursor-pointer">
              Book this Journey
            </button>
            <a href="/contact"
              class="w-full block text-center border border-border hover:border-teal text-ink-muted hover:text-teal font-bold py-4 rounded-xl transition-all text-sm">
              Custom Quote
            </a>
          </div>

          <div class="pt-6 border-t border-border space-y-3">
            <div class="flex justify-between text-sm">
              <span class="text-ink-muted">Destination</span>
              <span class="font-medium text-ink">{pkg.region}</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-ink-muted">Duration</span>
              <span class="font-medium text-ink">{pkg.days} Days</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-ink-muted">Type</span>
              <span class="font-medium text-ink">{pkg.is_international ? 'International' : 'Domestic'}</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <!-- Hidden metadata bridge to compiled script below -->
  <div id="package-metadata" 
       data-id={pkg.id} 
       data-title={pkg.title} 
       data-price={pkg.price} 
       data-images={JSON.stringify(allImages)} 
       hidden>
  </div>

  <!-- Sticky Mobile Booking Bar (Hidden on Desktop) -->
  <div class="fixed bottom-0 left-0 right-0 z-40 bg-white/90 backdrop-blur-md border-t border-border p-4 shadow-2xl flex items-center justify-between lg:hidden animate-fade-in">
    <div>
      <p class="text-[9px] uppercase tracking-widest text-ink-muted leading-none">Starting From</p>
      <p class="text-xl font-serif text-ink font-semibold">₱{pkg.price?.toLocaleString()}</p>
      <p class="text-ink-muted text-[10px]">{pkg.days} Days</p>
    </div>
    <button id="mobile-sticky-book-btn" class="bg-coral hover:bg-coral-dark text-white font-bold py-3 px-6 rounded-xl text-xs uppercase tracking-wider shadow-md cursor-pointer">
      Book Now
    </button>
  </div>
</PublicLayout>

<script>
  import { openInquiryModal } from '@lib/store';
  import { initGalleryLightbox } from '@lib/gallery_lightbox.js';

  // Hydrate logic only if elements and metadata exist
  const metaEl = document.getElementById('package-metadata');
  if (metaEl) {
    const pkgId = metaEl.dataset.id;
    const pkgTitle = metaEl.dataset.title;
    const pkgPrice = parseFloat(metaEl.dataset.price || '0');
    const allImages = JSON.parse(metaEl.dataset.images || '[]');

    const travelDateInput = document.getElementById('sidebar-travel-date') as HTMLInputElement;
    const btnDecAdults = document.getElementById('btn-dec-adults');
    const btnIncAdults = document.getElementById('btn-inc-adults');
    const btnDecChildren = document.getElementById('btn-dec-children');
    const btnIncChildren = document.getElementById('btn-inc-children');
    const lblAdults = document.getElementById('lbl-adults');
    const lblChildren = document.getElementById('lbl-children');
    const calculatedPriceHeader = document.getElementById('calculated-pax-price');
    const calculatedTotalSummary = document.getElementById('calculated-total-summary');

    let adults = 2;
    let children = 0;

    function updateCalculator() {
      const totalPax = adults + children;
      const totalEstimate = pkgPrice * totalPax;
      
      if (lblAdults) lblAdults.textContent = `${adults} Ad`;
      if (lblChildren) lblChildren.textContent = `${children} Ch`;
      
      if (calculatedPriceHeader) {
        calculatedPriceHeader.textContent = `₱${totalEstimate.toLocaleString()}`;
      }
      if (calculatedTotalSummary) {
        calculatedTotalSummary.textContent = `Estimated total for ${totalPax} guest${totalPax !== 1 ? 's' : ''}`;
      }
    }

    btnDecAdults?.addEventListener('click', () => { if (adults > 1) { adults--; updateCalculator(); } });
    btnIncAdults?.addEventListener('click', () => { adults++; updateCalculator(); });
    btnDecChildren?.addEventListener('click', () => { if (children > 0) { children--; updateCalculator(); } });
    btnIncChildren?.addEventListener('click', () => { children++; updateCalculator(); });

    // Initial load calculation
    updateCalculator();

    // Trigger modal and pass values cleanly through the store
    document.getElementById('detail-inquire-btn')?.addEventListener('click', () => {
      const dateVal = travelDateInput?.value || '';
      openInquiryModal(pkgId, pkgTitle, dateVal, adults, children);
    });

    // Initialize gallery lightbox
    initGalleryLightbox(allImages);
    
    document.getElementById('mobile-sticky-book-btn')?.addEventListener('click', () => {
      const dateVal = travelDateInput?.value || '';
      openInquiryModal(pkgId, pkgTitle, dateVal, adults, children);
    });
  }
  
</script>