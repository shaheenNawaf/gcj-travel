---
import { siteConfig } from '../config/site';
const pathname = new URL(Astro.request.url).pathname;
const isHome = pathname === "/";
---
<nav id="main-nav" class:list={["fixed top-0 w-full z-[100] transition-all duration-300", isHome ? "py-6" : "bg-ink py-4 border-b border-white/10"]}>
  <div class="container mx-auto px-6 flex justify-between items-center">
    <a href="/" class="text-white text-2xl font-serif tracking-tight group">
      {siteConfig.brand.name} <span class="font-light opacity-80 group-hover:opacity-100 transition-opacity">{siteConfig.brand.suffix}</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {siteConfig.nav.map((link) => (
        <a href={link.href} class="text-white/90 hover:text-white text-sm font-medium tracking-wide transition-colors">
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <a href="/contact" class="bg-coral hover:bg-coral-dark text-white px-5 py-2 rounded-full text-xs font-bold shadow-lg transition-all"> GET A QUOTE </a>
    </div>
  </div>
</nav>

<script define:vars={{ isHome }}>
  const nav = document.getElementById('main-nav');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav.style.background = 'rgba(13, 17, 23, 0.95)';
      nav.style.backdropFilter = 'blur(12px)';
      nav.style.borderBottom = '1px solid rgba(255,255,255,0.1)';
    } else {
      nav.style.background = '';
      nav.style.backdropFilter = '';
      nav.style.borderBottom = '';
    }
  });
</script>