---
import InquireButton from './InquireButton.jsx'; 
interface Props {
  pkg: {
    id: string;
    title: string;
    region: string;
    price: number;
    days: number;
    inclusions: string[];
    image_url: string;
  }
}

const { pkg } = Astro.props;
---

<!-- Fixed height and flexible card structure [2] -->
<div class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-border flex flex-col h-full">
  <!-- Image Container -->
  <a href={`/packages/${pkg.id}`} class="relative aspect-[4/3] overflow-hidden block flex-shrink-0">
    <img 
      src={pkg.image_url} 
      alt={pkg.title}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />
    <div class="absolute top-4 left-4 bg-teal-pale/90 backdrop-blur-md text-teal px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest border border-teal/20">
      {pkg.region}
    </div>
  </a>

  <!-- Content Stretch Wrapper [2] -->
  <div class="p-6 flex-1 flex flex-col justify-between">
    <div>
      <h3 class="text-2xl font-serif text-ink mb-2 group-hover:text-teal transition-colors">
        {pkg.title}
      </h3>
      
      <!-- Inclusions / Metadata -->
      <div class="flex flex-wrap gap-2 mb-6">
        <span class="text-xs font-mono text-ink-muted bg-sand px-2 py-1 rounded">
          {pkg.days} DAYS
        </span>
        {pkg.inclusions.slice(0, 3).map((item) => (
          <span class="text-[10px] font-sans text-ink-muted uppercase tracking-tighter border border-border px-2 py-1 rounded">
            {item}
          </span>
        ))}
        {pkg.inclusions.length > 3 && (
          <span class="text-[10px] font-sans text-ink-muted px-2 py-1">+{pkg.inclusions.length - 3} more</span>
        )}
      </div>
    </div>

    <!-- Pinned Footer Action blocks [2] -->
    <div class="pt-4 border-t border-border mt-6">
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="text-[10px] text-ink-muted uppercase tracking-widest leading-none mb-1">Starting from</p>
          <p class="text-xl font-mono text-teal font-bold">₱{pkg.price.toLocaleString()}</p>
        </div>
        <InquireButton client:visible pkgId={pkg.id} pkgTitle={pkg.title} />
      </div>
      <a href={`/packages/${pkg.id}`}
        class="block w-full text-center border border-border hover:border-teal text-ink-muted hover:text-teal font-bold py-3 rounded-xl transition-all text-xs tracking-widest uppercase">
        View Details
      </a>
    </div>
  </div>
</div>