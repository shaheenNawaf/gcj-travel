---
import { siteConfig } from '@config/site'; 
const year = new Date().getFullYear();
---

<footer class="bg-ink text-white">
  <!-- Main Footer Grid -->
  <div class="container mx-auto px-6 py-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">

      <!-- Brand Column -->
      <div class="md:col-span-2">
        <a href="/" class="text-white text-3xl font-serif tracking-tight">
          {siteConfig.brand.name} <span class="font-light opacity-60 italic">{siteConfig.brand.suffix}</span>
        </a>
        <p class="text-white/50 mt-4 text-sm leading-relaxed max-w-xs">
          {siteConfig.brand.description}
        </p>
        
        <!-- Social Media Links -->
        <div class="flex gap-4 mt-8">
          {siteConfig.contact.facebook && (
            <a href={siteConfig.contact.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-white/50 hover:text-white hover:border-white/40 transition-all text-xs font-bold">
              FB
            </a>
          )}
          {siteConfig.contact.instagram && (
            <a href={siteConfig.contact.instagram} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-white/50 hover:text-white hover:border-white/40 transition-all text-xs font-bold">
              IG
            </a>
          )}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/30 mb-6">Explore</p>
        <div class="flex flex-col gap-3">
          {siteConfig.nav.map((link) => (
            <a href={link.href} class="text-white/60 hover:text-white text-sm transition-colors">
              {link.label}
            </a>
          ))}
          <a href="/packages" class="text-white/60 hover:text-white text-sm transition-colors uppercase">All Packages</a>
        </div>
      </div>

      <!-- Contact Information -->
      <div>
        <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/30 mb-6">Get in Touch</p>
        <div class="flex flex-col gap-4">
          <div>
            <p class="text-[10px] text-white/30 uppercase tracking-widest mb-1">Phone</p>
            <a href={`tel:${siteConfig.contact.phone}`} class="text-sm text-white/70 hover:text-white transition-colors">
              {siteConfig.contact.phone}
            </a>
          </div>
          <div>
            <p class="text-[10px] text-white/30 uppercase tracking-widest mb-1">Email</p>
            <a href={`mailto:${siteConfig.contact.email}`} class="text-sm text-white/70 hover:text-white transition-colors">
              {siteConfig.contact.email}
            </a>
          </div>
          <div>
            <p class="text-[10px] text-white/30 uppercase tracking-widest mb-1">Address</p>
            <p class="text-sm text-white/70">{siteConfig.contact.address}</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom Accreditation Bar -->
  <div class="border-t border-white/5">
    <div class="container mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/20 text-xs">
        &copy; {year} {siteConfig.brand.name} {siteConfig.brand.suffix}. All rights reserved.
      </p>
      
      <!-- Accreditation badges are conditionally rendered based on site.js config settings -->
      <div class="flex gap-6">
        {siteConfig.accreditations?.dotLicensed && (
          <span class="text-white/25 hover:text-white/50 text-xs transition-colors cursor-help" title="Department of Tourism Licensed Agency">DOT Accredited</span>
        )}
        {siteConfig.accreditations?.ptaaMember && (
          <span class="text-white/25 hover:text-white/50 text-xs transition-colors cursor-help" title="Philippine Travel Agencies Association Member">PTAA Member</span>
        )}
        {siteConfig.accreditations?.iataAccredited && (
          <span class="text-white/25 hover:text-white/50 text-xs transition-colors cursor-help" title="International Air Transport Association Accredited">IATA Accredited</span>
        )}
      </div>
    </div>
  </div>
</footer>