---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import InquiryModal from '../components/InquiryModal.jsx';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { 
  title, 
  description = siteConfig.seo.defaultDescription,
  ogImage = siteConfig.seo.ogImage 
} = Astro.props;

const displayTitle = title 
  ? `${title} | ${siteConfig.brand.name} ${siteConfig.brand.suffix}`
  : siteConfig.seo.defaultTitle;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{displayTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={siteConfig.seo.keywords.join(', ')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={displayTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
  </head>
  <body class="bg-surface">
    <Navbar />
    <slot />
    <Footer />
    <InquiryModal client:load />

    <!-- Exit Intent Modal -->
    <div id="exit-popup" class="hidden fixed inset-0 z-[200] flex items-center justify-center p-6">
      <div id="exit-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
      <div class="relative bg-white rounded-3xl max-w-lg w-full overflow-hidden shadow-2xl transform transition-all">
        <div class="h-3 bg-gradient-to-r from-teal via-coral to-teal"></div>
        <div class="p-10 text-center">
          <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-coral mb-3">Wait — Before You Go</p>
          <h2 class="text-4xl font-serif text-ink mb-3 leading-tight">
            Your dream trip <br/><span class="italic text-ink/50">is one message away.</span>
          </h2>
          <p class="text-ink-muted text-sm mb-8 leading-relaxed">
            Let one of our travel specialists put together a custom package for you — no commitment, no pressure.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/contact" class="flex-1 bg-ink hover:bg-teal text-white font-bold py-4 rounded-xl transition-all text-sm block text-center">
              Talk to a Specialist
            </a>
            <button id="exit-dismiss" class="flex-1 bg-sand hover:bg-border text-ink-muted font-bold py-4 rounded-xl transition-all text-sm cursor-pointer">
              Maybe Later
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Floating action links using CSS classes linked to global.css -->
     <a id="whatsapp-btn" href={`https://wa.me/${siteConfig.contact.whatsapp}?text=Hi!%20I'm%20interested%20in%20your%20travel%20packages.`} target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <a href="/contact" id="quote-btn" aria-label="Get a Quote">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
    </a>

    <button id="scroll-top" aria-label="Scroll to top">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 19V5M5 12l7-7 7 7"/>
      </svg>
    </button>
  </body>
</html>

<script>
  import { initScrollAndFloatingButtons, initExitIntentPopup } from '../lib/client_utils.js';
  
  // Initialize on client load
  initScrollAndFloatingButtons();
  initExitIntentPopup();
</script>