---
import '../styles/global.css';
import { siteConfig } from '../config/site';
const { title = "Admin" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title} | Editor's Desk</title>
    <meta name="viewport" content="width=device-width" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,400&family=DM+Sans:wght@400;500;700&family=DM+Mono&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="admin-grid">
      <!-- SIDEBAR -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <a href="/" class="logo">
            {siteConfig.brand.name} <span class="logo-suffix">Edition</span>
          </a>
        </div>
        
        <nav class="sidebar-nav">
          <p class="nav-label">Management</p>
          <a href="/admin/inquiries" class:list={["nav-link", { active: currentPath === '/admin/inquiries' }]}>
            Inquiries <span class="badge">New</span>
          </a>
          <a href="/admin/packages" class:list={["nav-link", { active: currentPath.startsWith('/admin/packages') }]}>
            Tour Catalog
          </a>
          <a href="/admin/media" class:list={["nav-link", { active: currentPath === '/admin/media' }]}>
            Media Assets
          </a>
        </nav>

        <div class="sidebar-footer">
          <div class="user-profile">
            <div class="avatar">AD</div>
            <div class="user-info">
              <p class="user-name">Admin User</p>
              <p class="user-role">Editor-in-Chief</p>
            </div>
          </div>
          <button id="logout-btn" class="logout-button">SECURE SIGN OUT</button>
        </div>
      </aside>

      <!-- MAIN CONTENT -->
      <div class="main-wrapper">
        <header class="main-header">
           <span class="header-title">{title}</span>
           <div class="system-status">
              <div class="status-dot"></div>
              <span>SYSTEM LIVE</span>
           </div>
        </header>

        <main class="content-area">
          <div class="content-container">
            <slot />
          </div>
        </main>
      </div>
    </div>

    <style>
      /* FORCE LAYOUT LOGIC */
      :global(body) {
        margin: 0;
        padding: 0;
        overflow: hidden;
        background-color: #fcfcfb;
      }

      .admin-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        height: 100vh;
        width: 100vw;
      }

      .sidebar {
        background-color: #0d1117;
        color: white;
        display: flex;
        flex-direction: column; /* FORCES VERTICAL STACK */
        height: 100%;
        border-right: 1px solid rgba(255,255,255,0.1);
      }

      .sidebar-header { padding: 32px; }
      .logo { font-family: 'Cormorant Garamond', serif; font-size: 24px; color: white; text-decoration: none; }
      .logo-suffix { opacity: 0.4; font-style: italic; font-weight: 300; }

      .sidebar-nav {
        flex: 1;
        padding: 0 16px;
        display: flex;
        flex-direction: column; /* FORCES LINKS TO STACK */
        gap: 4px;
      }

      .nav-label { 
        padding: 0 16px; 
        font-size: 10px; 
        font-weight: bold; 
        text-transform: uppercase; 
        letter-spacing: 0.2em; 
        color: rgba(255,255,255,0.3);
        margin-bottom: 16px;
      }

      .nav-link {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
        border-radius: 12px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        font-size: 14px;
        transition: all 0.2s;
      }
      .nav-link:hover { background: rgba(255,255,255,0.05); color: white; }
      .nav-link.active { background: #1a6b6b; color: white; }

      .badge { background: #1a6b6b; font-size: 10px; padding: 2px 8px; border-radius: 99px; }

      .sidebar-footer { padding: 32px; border-top: 1px solid rgba(255,255,255,0.05); }
      .user-profile { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
      .avatar { width: 32px; height: 32px; background: #1a6b6b; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; }
      .user-name { margin: 0; font-size: 12px; font-weight: bold; }
      .user-role { margin: 0; font-size: 12px; opacity: 0.4; }
      .logout-button { background: none; border: none; color: rgba(255,255,255,0.4); font-size: 10px; font-weight: bold; letter-spacing: 0.1em; cursor: pointer; padding: 0; }
      .logout-button:hover { color: white; }

      .main-wrapper {
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
      }

      .main-header {
        height: 80px;
        background: white;
        border-bottom: 1px solid #e2ddd7;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 48px;
      }

      .header-title { font-family: 'DM Mono', monospace; font-size: 12px; color: #4b5563; text-transform: uppercase; letter-spacing: 0.1em; }
      .system-status { display: flex; align-items: center; gap: 8px; font-size: 10px; font-weight: bold; letter-spacing: 0.1em; }
      .status-dot { width: 8px; height: 8px; background: #1a6b6b; border-radius: 50%; }

      .content-area {
        flex: 1;
        overflow-y: auto;
        padding: 48px;
      }

      .content-container { max-width: 1100px; margin: 0 auto; }
    </style>

    <script>
      import { supabase } from '../lib/supabase_client';
      const checkUser = async () => {
        const { data: { session } } = await supabase.auth.getSession();
        if (!session && window.location.pathname !== '/admin/login') {
            window.location.href = '/admin/login';
        }
      };
      checkUser();
      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/admin/login';
      });
    </script>
  </body>
</html>